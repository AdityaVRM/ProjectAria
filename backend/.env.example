# Cursor API key (required — Cursor Dashboard → Integrations)
CURSOR_COMPOSER_1_5_API_KEY=your_cursor_api_key_here

# GitHub repo for Cloud Agents (must be accessible to your Cursor account)
CURSOR_REPO=https://github.com/YOUR_USER/YOUR_REPO

# Model: composer-1.5 | claude-4.6-opus-high-thinking | gpt-5.3-codex-high | gpt-5.2-high
CURSOR_MODEL=composer-1.5

ENVIRONMENT=development
MEMORY_BACKEND=memory
# MEMORY_BACKEND=sqlite
# DATABASE_URL=sqlite+aiosqlite:///./solos_memory.db
